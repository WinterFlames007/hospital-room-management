<div class="form-page">

    <div class="form-container">

        <div class="page-header">

            <div>

                <h2>Edit Assignment</h2>

                <p>
                    Update patient room assignment details
                </p>

            </div>

        </div>

        <form
            action="/assignments/edit/<%= assignment.assignment_id %>"
            method="POST"
            class="styled-form"
        >

            <div class="form-grid">

                <!-- PATIENT -->

                <div class="form-group">

                    <label>
                        Patient
                    </label>

                    <select
                        name="patient_id"
                        required
                    >

                        <% patients.forEach(patient => { %>

                            <option
                                value="<%= patient.patient_id %>"
                                <%= assignment.patient_id === patient.patient_id
                                    ? 'selected'
                                    : ''
                                %>
                            >

                                <%= patient.full_name %>

                            </option>

                        <% }) %>

                    </select>

                </div>

                <!-- ROOM -->

                <div class="form-group">

                    <label>
                        Room
                    </label>

                    <select
                        name="room_id"
                        required
                    >

                        <% rooms.forEach(room => { %>

                            <option
                                value="<%= room.room_id %>"
                                <%= assignment.room_id === room.room_id
                                    ? 'selected'
                                    : ''
                                %>
                            >

                                Room <%= room.room_number %>
                                - <%= room.room_type %>

                            </option>

                        <% }) %>

                    </select>

                </div>

            </div>

            <!-- STATUS -->

            <div class="form-group">

                <label>
                    Assignment Status
                </label>

                <select
                    name="status"
                    required
                >

                    <option
                        value="Active"
                        <%= assignment.status === 'Active'
                            ? 'selected'
                            : ''
                        %>
                    >
                        Active
                    </option>

                    <option
                        value="Completed"
                        <%= assignment.status === 'Completed'
                            ? 'selected'
                            : ''
                        %>
                    >
                        Completed
                    </option>

                </select>

            </div>

            <!-- BUTTONS -->

            <div class="form-actions">

                <button
                    type="submit"
                    class="btn"
                >

                    Update Assignment

                </button>

                <a
                    href="/assignments"
                    class="btn secondary-btn"
                >
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>