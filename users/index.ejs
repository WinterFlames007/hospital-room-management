
<div class="dashboard-header">

    <h2>User Management</h2>

    <p>
        Manage system accounts and permissions
    </p>

</div>

<!-- SEARCH + FILTER -->

<form
    method="GET"
    action="/users"
    class="filter-form"
>

    <div class="filter-grid">

        <!-- SEARCH -->

        <div class="search-wrapper">

            <input
                type="text"
                name="search"
                placeholder="Search users..."
                value="<%= search %>"
            >

            <button type="submit">

                <i class="fa-solid fa-magnifying-glass"></i>

            </button>

        </div>

        <!-- ROLE FILTER -->

        <select name="role">

            <option value="">
                All Roles
            </option>

            <option
                value="admin"
                <%= role === 'admin'
                    ? 'selected'
                    : ''
                %>
            >
                Admin
            </option>

            <option
                value="hospital_admin"
                <%= role === 'hospital_admin'
                    ? 'selected'
                    : ''
                %>
            >
                Hospital Admin
            </option>

            <option
                value="staff"
                <%= role === 'staff'
                    ? 'selected'
                    : ''
                %>
            >
                Staff
            </option>

        </select>

    </div>

</form>

<!-- USERS TABLE -->

<div class="table-container">

    <table>

        <thead>

            <tr>

                <th>Name</th>

                <th>Email</th>

                <th>Role</th>

                <th>Status</th>

                <th>Online</th>

                <th>Last Login</th>

                <th>Actions</th>

            </tr>

        </thead>

        <tbody>

            <% users.forEach(user => { %>

                <tr>

                    <td data-label="Name">

                        <%= user.full_name %>

                    </td>

                    <td data-label="Email">

                        <%= user.email %>

                    </td>

                    <td data-label="Role">

                        <span class="role-badge">

                            <%= user.role %>

                        </span>

                    </td>

                    <!-- STATUS -->

                    <td data-label="Status">

                        <% if (user.is_active) { %>

                            <span class="status active">

                                Active

                            </span>

                        <% } else { %>

                            <span class="status high">

                                Disabled

                            </span>

                        <% } %>

                    </td>

                    <!-- ONLINE -->

                    <td data-label="Online">

                        <% if (user.is_online) { %>

                            <span class="online-status online">

                                <i class="fa-solid fa-circle"></i>

                                Online

                            </span>

                        <% } else { %>

                            <span class="online-status offline">

                                <i class="fa-solid fa-circle"></i>

                                Offline

                            </span>

                        <% } %>

                    </td>



                    <!-- LAST LOGIN -->


                    <td data-label="Last Login" class="last-login-cell">

                        <% if (user.last_login) { %>

                            <%= new Date(user.last_login).toLocaleString(
                                'en-GB',
                                {
                                    weekday: 'short',
                                    year: 'numeric',
                                    month: 'short',
                                    day: 'numeric',
                                    hour: '2-digit',
                                    minute: '2-digit'
                                }
                            ) %>

                        <% } else { %>

                            Never

                        <% } %>

                    </td>



                    <!-- ACTIONS -->

                    <td data-label="Actions">


                        <div class="table-actions">

                            <a
                                href="/users/edit/<%= user.user_id %>"
                                class="btn"
                            >
                                Edit
                            </a>

                            <form

                                action="/users/toggle-status/<%= user.user_id %>"
                                method="POST"
                            >

                                <button
                                    type="submit"
                                    class="btn"
                                >

                                    <% if (user.is_active) { %>

                                        Deactivate

                                    <% } else { %>

                                        Activate

                                    <% } %>

                                </button>

                            </form>

                        </div>


                    </td>


                </tr>

            <% }) %>

        </tbody>

    </table>

</div>

<!-- PAGINATION -->

<div class="pagination">

    <% for(let i = 1; i <= totalPages; i++) { %>

        <a
            href="/users?page=<%= i %>&search=<%= search %>&role=<%= role %>"
            class="
                pagination-btn
                <%= currentPaginationPage === i ? 'active-page' : '' %>
            "
        >
            <%= i %>
        </a>

    <% } %>

</div>