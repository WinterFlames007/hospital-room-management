<div class="form-page">

    <div class="form-container">

        <div class="page-header">

            <div>

                <h2>Transfer Patient</h2>

                <p>
                    Move patient to another available room
                </p>

            </div>

        </div>

        <!-- CURRENT DETAILS -->

        <div class="info-card">

            <div class="info-grid">

                <div class="info-item">

                    <label>Current Patient</label>

                    <p>
                        <%= assignment.patient_name %>
                    </p>

                </div>

                <div class="info-item">

                    <label>Current Room</label>

                    <p>
                        Room <%= assignment.current_room_number %>
                    </p>

                </div>

                <div class="info-item">

                    <label>Priority Level</label>

                    <p>
                        <%= assignment.isolation_priority %>
                    </p>

                </div>

            </div>

        </div>

        <!-- TRANSFER FORM -->

        <form
            action="/assignments/transfer/<%= assignment.assignment_id %>"
            method="POST"
            class="styled-form"
        >

            <div class="form-group">

                <label>
                    Select New Room
                </label>

                <select
                    name="new_room_id"
                    required
                >

                    <% rooms.forEach(room => { %>

                        <option
                            value="<%= room.room_id %>"
                        >

                            Room <%= room.room_number %>
                            - <%= room.room_type %>

                        </option>

                    <% }) %>

                </select>

            </div>

            <!-- ACTIONS -->

            <div class="form-actions">

                <button
                    type="submit"
                    class="btn"
                >

                    Transfer Patient

                </button>

                <a
                    href="/assignments"
                    class="btn secondary-btn"
                >
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>